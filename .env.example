# Copy to .env and fill in. .env is gitignored.

# Oanda API token from https://www.oanda.com/account/tpa/personal_token
OANDA_API_KEY=your-token-here

# Your Oanda account ID (e.g. 101-004-1234567-001)
OANDA_ACCOUNT_ID=your-account-id

# "practice" for the demo/fxpractice environment, "live" for real money.
OANDA_ENV=practice
